    {
      "cell_type": "code",
      "source": [
        "train_url = 'https://raw.githubusercontent.com/byui-cse/cse450-course/master/data/housing.csv'\n",
        "holdout_url = 'https://raw.githubusercontent.com/byui-cse/cse450-course/master/data/housing_holdout_test.csv'\n",
        "\n",
        "df_train = pd.read_csv(train_url)\n",
        "df_holdout = pd.read_csv(holdout_url)"
      ],
      "metadata": {
        "id": "4EOuR8EacjhH"
      },
      "execution_count": 70,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def preprocess_pipeline(df):\n",
        "    df_clean = df.copy()\n",
        "\n",
        "    for col in df_clean.select_dtypes(include=[np.number]).columns:\n",
        "        if df_clean[col].isnull().sum() > 0:\n",
        "            df_clean[col] = df_clean[col].fillna(df_clean[col].median())\n",
        "\n",
        "    if 'yr_built' in df_clean.columns:\n",
        "        df_clean['construction_age'] = 2026 - df_clean['yr_built']\n",
        "        df_clean['age_bin'] = pd.cut(df_clean['construction_age'],\n",
        "                                     bins=[0, 10, 30, 50, 100, 200],\n",
        "                                     labels=['New', 'Modern', 'Mid-Age', 'Old', 'Historic'])\n",
        "        df_clean = df_clean.drop(columns=['yr_built'])\n",
        "\n",
        "    drop_cols = ['id', 'date']\n",
        "    df_clean = df_clean.drop(columns=[col for col in drop_cols if col in df_clean.columns])\n",
        "\n",
        "    return df_clean\n",
        "df_train_clean = preprocess_pipeline(df_train)\n",
        "df_holdout_clean = preprocess_pipeline(df_holdout)"
      ],
      "metadata": {
        "id": "vdX5y4XGdosY"
      },
      "execution_count": 71,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "X = df_train_clean.drop(columns=['price'])\n",
        "y = df_train_clean['price']"
      ],
      "metadata": {
        "id": "3mwtSDSodo1J"
      },
      "execution_count": 72,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "X_encoded = pd.get_dummies(X, drop_first=True)\n",
        "X_holdout_encoded = pd.get_dummies(df_holdout_clean, drop_first=True)\n",
        "\n",
        "if 'price' in X_holdout_encoded.columns:\n",
        "    X_holdout_encoded = X_holdout_encoded.drop(columns=['price'])\n",
        "X_holdout_final = X_holdout_encoded.reindex(columns=X_encoded.columns, fill_value=0)"
      ],
      "metadata": {
        "id": "cNF63v3acjjM"
      },
      "execution_count": 73,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "X_train, X_test, y_train, y_test = train_test_split(X_encoded, y, test_size=0.2, random_state=42)\n",
        "model = XGBRegressor(\n",
        "n_estimators=300,\n",
        "learning_rate=0.05,\n",
        "max_depth=6,\n",
        "subsample=0.8,\n",
        "colsample_bytree=0.8,\n",
        "random_state=42,\n",
        "n_jobs=-1\n",
        ")\n",
        "model.fit(X_train, y_train)"
